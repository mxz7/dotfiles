# font
font-feature = -liga
font-feature = -calt
font-feature = -dlig
font-size = 14
font-family = sf mono
font-thicken = true
font-thicken-strength = 0

# increases line height
adjust-cell-height = 10%

# background blur
background-opacity = 0.8
background-blur = macos-glass-clear

# keybinds
keybind = super+backspace=text:\x15
keybind = opt+backspace=text:\x17

# window
window-colorspace = display-p3

window-padding-balance = true
window-padding-color = background
window-padding-x = 5
window-padding-y = 3

window-height = 35
window-width = 140

scrollback-limit = 10000000

theme = nord-custom
# theme = everblush
# theme = idle toes

macos-titlebar-proxy-icon = hidden

shell-integration-features = ssh-env,no-cursor
cursor-style = block
